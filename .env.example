# ============================================================
# .env.example — шаблон переменных окружения
# Скопируйте в .env и заполните своими значениями.
# Файл .env НЕ коммитится в git (.gitignore уже содержит исключение).
# ============================================================

# ----------------------------------------------------------
# Django core
# ----------------------------------------------------------

# Обязательно. Сгенерировать: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-secret-key-here

# True только для локальной разработки. На проде всегда False.
DEBUG=True

# Список хостов через запятую. Пример: example.com,www.example.com
# Для локальной разработки: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------
# База данных
# ----------------------------------------------------------

# Для локальной разработки оставьте DB_ENGINE пустым → будет использован SQLite.
# Для PostgreSQL на проде раскомментируйте и заполните строки ниже:

# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=portfolio_db
# DB_USER=portfolio_user
# DB_PASSWORD=strong-password-here
# DB_HOST=localhost
# DB_PORT=5432

# Время жизни постоянного соединения (секунды). 0 — без keep-alive.
# Убрать (или поставить 0) при использовании PgBouncer в режиме transaction.
# DB_CONN_MAX_AGE=600
